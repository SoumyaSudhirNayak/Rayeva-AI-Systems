# Environment variables for SustainCommerce SaaS
# Copy this file to .env and fill in your values

# Hugging Face Access Token (Inference Providers)
HUGGINGFACE_API_KEY="hf_your_token_here"

# Optional: override model used by the backend (Inference Providers style)
HUGGINGFACE_MODEL="meta-llama/Llama-4-Scout-17B-16E-Instruct:groq"

# Supabase Database Connection
database_url="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"
public_key="your-supabase-public-key"
anon_key="your-supabase-anon-key"
project_url="https://your-project.supabase.co"
